{
  "name": "@elastic/micro-jq",
  "version": "1.9.1",
  "description": "Small implementation of jq",
  "main": "./dist/index.js",
  "license": "Apache-2.0",
  "packageManager": "npm@10.8.1",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "url": "https://github.com/elastic/micro-jq"
  },
  "bin": "./dist/cli.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "peggy --plugin ts-pegjs --cache -o ./src/parser.ts ./src/parser.pegjs && tsc --declaration --outDir dist",
    "lint": "eslint --cache src test",
    "lint-fix": "eslint --cache --fix src test",
    "test": "npm run lint && npm run build && npm exec -- jest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "peggy": "^3.0.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "ts-pegjs": "^4.2.1",
    "typescript": "^6.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "noImplicitAny": false
          }
        }
      ]
    }
  }
}
